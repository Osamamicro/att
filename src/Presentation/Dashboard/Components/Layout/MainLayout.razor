@inherits LayoutComponentBase
@inject NavigationManager Nav
@inject IJSRuntime JSRuntime

    <!-- Layout wrapper -->
    <div class="layout-wrapper layout-content-navbar">
        <div class="layout-container">

            <!-- Layout container -->
            <div class="layout-page" style="padding-left:0px">
                <!-- Navbar -->

                <nav class="layout-navbar container-xxl navbar navbar-expand-xl navbar-detached align-items-center bg-navbar-theme" id="layout-navbar" style="padding-left:0px;left:0px;">
                    <div class="container-fluid d-flex align-items-center justify-content-between">
                        <div class="d-flex align-items-center gap-2">
                            <span class="badge bg-label-primary p-2"><i class="ti ti-layout-grid"></i></span>
                            <div>
                                <div class="fw-semibold">لوحة المتابعة</div>
                                <small class="text-muted">الحضور والموظفين</small>
                            </div>
                        </div>

                        <div class="d-flex align-items-center gap-3">
                            <button class="btn btn-outline-danger d-flex align-items-center gap-2"
                                    type="button"
                                    data-bs-toggle="modal"
                                    data-bs-target="#logoutConfirmModal">
                                <i class="ti ti-logout"></i>
                                <span>تسجيل الخروج</span>
                            </button>
                        </div>
                    </div>
                </nav>

                <!-- / Navbar -->
                <!-- Content wrapper -->
                <div class="content-wrapper">
                    <!-- Content -->
                    <Loader Visible="@IsLoading" />
                    <div class="container-xxl flex-grow-1 container-p-y">
                        @Body
                    </div>
                    <!-- / Content -->
                    <div class="content-backdrop fade"></div>

                    <div id="blazor-error-ui" data-nosnippet>
                        An unhandled error has occurred.
                        <a href="." class="reload">Reload</a>
                        <span class="dismiss">🗙</span>
                    </div>

                </div>
                <!-- Content wrapper -->
            </div>
            <!-- / Layout page -->
        </div>

        <div class="modal fade" id="logoutConfirmModal" tabindex="-1" aria-labelledby="logoutConfirmModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="logoutConfirmModalLabel">تأكيد تسجيل الخروج</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        هل تريد إتمام تسجيل الخروج؟
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">لا، تراجع</button>
                        <button type="button" class="btn btn-danger" @onclick="HandleLogout" data-bs-dismiss="modal">نعم، تسجيل الخروج</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Overlay -->
        <div class="layout-overlay layout-menu-toggle"></div>

        <!-- Drag Target Area To SlideIn Menu On Small Screens -->
        <div class="drag-target"></div>
    </div>
    <!-- / Layout wrapper -->
@code {
    private bool IsLoading = false;
    private bool _firstRender = true;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += (_, __) =>
        {
            IsLoading = true;
            StateHasChanged();
        };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_firstRender)
        {
            await Task.Delay(300);
            IsLoading = false;
            StateHasChanged();
        }

        _firstRender = false;
    }

    private async Task HandleLogout()
    {
        await JSRuntime.InvokeVoidAsync("authStorage.clearAuth");
        Nav.NavigateTo("/login", true);
    }
}